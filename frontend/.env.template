# FastAPI backend used by the storefront.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# Storefront URL.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default country/region code used by middleware.
NEXT_PUBLIC_DEFAULT_REGION=cn

# Optional Stripe public key if backend-native payments are connected later.
NEXT_PUBLIC_STRIPE_KEY=

# Next.js revalidation secret.
REVALIDATE_SECRET=supersecret

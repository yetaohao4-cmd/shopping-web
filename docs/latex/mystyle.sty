\ProvidesPackage{mystyle}

% --- 页面设置 ---
% 模板正文页：A4，左右约 89.85pt，上下约 1in
\RequirePackage[a4paper, left=3.17cm, right=3.17cm, top=2.54cm, bottom=2.54cm]{geometry}

\RequirePackage{graphicx}
\RequirePackage{titletoc}
\RequirePackage{setspace}
\RequirePackage{fontspec} % 统一提到上方
\RequirePackage[AutoFakeBold=true]{xeCJK} 
\RequirePackage{xcolor}
\RequirePackage{caption}
\RequirePackage{etoolbox}

% ==========================================
% --- 字体定义 (全部指向 ./fonts/ 目录) ---
% ==========================================

% 1. 全局默认中文字体设为宋体
\setCJKmainfont{宋体.ttc}[Path=./fonts/, AutoFakeBold=true]
\setmainfont{Times New Roman}

% 2. 重新定义 \songti 和 \heiti 命令，强行绑定到本地文件
\setCJKfamilyfont{mysong}{宋体.ttc}[Path=./fonts/, AutoFakeBold=true]
\renewcommand{\songti}{\CJKfamily{mysong}}

% 使用截图中的 黑体.ttf (如果你想用高亮的那款方正黑体，这里换成 方正黑体_GBK.ttf)
\setCJKfamilyfont{myhei}{黑体.ttf}[Path=./fonts/, AutoFakeBold=true]
\renewcommand{\heiti}{\CJKfamily{myhei}}

% 3. 定义等线字体 (⚠️ 警告：截图中没有等线，请确保你放入了 dengxian.ttf)
% 3. 定义等线字体 (精准调用你提供的三个文件)
\setCJKfamilyfont{mydeng}{Deng.ttf}[
Path = ./fonts/,
BoldFont = Dengb.ttf  % 指定真实的粗体文件，排版效果远超 AutoFakeBold
]
\newcommand{\dengxian}{\CJKfamily{mydeng}}

% 4. 为章节数字专门定义的西文字体族 (指向本地的黑体)
\newfontfamily\strictnumberheiti{黑体.ttf}[Path=./fonts/, AutoFakeBold=true] 

% ==========================================


% --- 全局正文设置 ---
% 模板正文：宋体 / Times New Roman，12pt，固定 20pt 行距，首行缩进 2 字符
\renewcommand{\normalsize}{\fontsize{12pt}{20pt}\selectfont\songti\color{black}}
\renewcommand{\small}{\fontsize{10pt}{12pt}\selectfont\songti\color{black}}
\AtBeginDocument{%
	\normalsize
	\setlength{\parindent}{2em}
	\setlength{\parskip}{0pt}
}


% --- 标题格式定义 (\ctexset) ---
\ctexset{
	chapter = {
		format = {\fontsize{15pt}{20pt}\selectfont\heiti\bfseries\centering\color{black}},
		name = {, },
		number = \arabic{chapter},
		afterskip = 16.5pt,
		beforeskip = 17pt
	},
	section = {
		format = {\fontsize{14pt}{20pt}\selectfont\songti\bfseries\raggedright\color{black}},
		numberformat = {\fontsize{14pt}{20pt}\selectfont\songti\bfseries\color{black}},
		afterskip = 0pt,
		beforeskip = 13pt
	},
	subsection = {
		format = {\fontsize{10.5pt}{12pt}\selectfont\heiti\raggedright\color{black}},
		numberformat = {\fontsize{10.5pt}{12pt}\selectfont\heiti\color{black}},
		afterskip = 0pt,
		beforeskip = 13pt
	}
}

% --- 图题、表题与表格文字 ---
\DeclareCaptionFont{templatecaption}{\heiti\fontsize{10pt}{12pt}\selectfont\color{black}}
\captionsetup{
	font=templatecaption,
	labelfont=templatecaption,
	labelsep=space,
	justification=centering,
	skip=6pt
}
\AtBeginEnvironment{tabular}{\fontsize{10pt}{12pt}\selectfont\songti\color{black}}

% --- 目录核心设置 ---
\setcounter{tocdepth}{1} 

% 目录标题：等线, 15.96pt, 行距1.20倍, 抵消默认的段后距
\renewcommand{\contentsname}{%
	\centerline{\dengxian\fontsize{15.96pt}{19.15pt}\selectfont 目\hspace{1em}录}%
	\vspace{-8.42pt}%
}

% --- 目录列表样式 (titletoc) ---
% 一级目录项 (Chapter) 
% 整体环境为等线，因此数字、文字、页码全为等线
\titlecontents{chapter}[0pt]{\addvspace{5pt}\heiti\fontsize{14pt}{20pt}\selectfont}
{\thecontentslabel\quad} 
{}
{\titlerule*[5pt]{.}\contentspage}

% 二级目录项 (Section)
% 基础文字为宋体，但前面的数字(\thecontentslabel)和后面的页码(\contentspage)局部设为等线
\titlecontents{section}[2.5em]{\addvspace{2pt}\songti\fontsize{12pt}{20pt}\selectfont}
{{\songti\thecontentslabel}\quad} 
{}
{\titlerule*[5pt]{.}{\songti\contentspage}}

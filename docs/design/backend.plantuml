@startuml online_shopping_domain
title Online Shopping Backend Domain

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
left to right direction

' =========================
' Enumerations
' =========================

package "Enums" {
  enum AccountStatus {
    ACTIVE
    BLOCKED
    BANNED
    COMPROMISED
    ARCHIVED
    UNKNOWN
  }

  enum OrderStatus {
    CREATED
    CONFIRMED
    PROCESSING
    SHIPPED
    COMPLETED
    CANCELED
  }

  enum RefundStatus {
    NONE
    REQUESTED
    APPROVED
    REJECTED
    REFUNDED
  }

  enum PaymentStatus {
    UNPAID
    PENDING
    COMPLETED
    FAILED
    DECLINED
    CANCELED
    ABANDONED
    SETTLING
    SETTLED
    REFUNDED
  }

  enum PaymentMethodType {
    CREDIT_CARD
    ELECTRONIC_BANK_TRANSFER
  }

  enum ShipmentStatus {
    PENDING
    SHIPPED
    DELIVERED
    ON_HOLD
  }

  enum NotificationChannel {
    EMAIL
    SMS
  }
}

' =========================
' Interfaces
' =========================

package "Interfaces" {
  interface Search {
    + search_products_by_name(name: ProductName): list[object]
    + search_products_by_category(category: CategoryName): list[object]
  }
}

' =========================
' API / Schemas
' =========================

package "API / Schemas" {
  class CategoryBase <<schema>>
  class CategoryCreate <<schema>>
  class CategoryOut <<schema>>

  class ProductBase <<schema>>
  class ProductCreate <<schema>>
  class ProductOut <<schema>>

  class CartItemCreate <<schema>>
  class CartItemUpdate <<schema>>
  class CartItemOut <<schema>>
  class ShoppingCartOut <<schema>>

  class PaymentCreate <<schema>>
  class PaymentOut <<schema>>
  class ShipmentOut <<schema>>

  class OrderCreate <<schema>>
  class OrderOut <<schema>>
}

' =========================
' API / Routers
' =========================

package "API / Routers" {
  class FastAPIApp <<module>> {
    + create_app(): FastAPI
  }

  class HealthRouter <<router>>
  class ProductRouter <<router>>
  class RegionRouter <<router>>
  class CartRouter <<router>>
  class OrderRouter <<router>>
  class PaymentRouter <<router>>

  class Store <<fake repository>> {
    - _products: list[ProductOut]
    - _cart_items: list[CartItemOut]
    - _orders: dict[str, OrderOut]
    + list_products(): list[ProductOut]
    + list_categories(): list[CategoryOut]
    + find_product(product_name: str): ProductOut | None
    + create_product(payload: ProductCreate): ProductOut
    + get_cart(): ShoppingCartOut
    + add_cart_item(payload: CartItemCreate): CartItemOut | None
    + update_cart_item(product_name: str, quantity: int): CartItemOut | None
    + remove_cart_item(product_name: str): bool
    + list_orders(): list[OrderOut]
    + get_order(order_number: str): OrderOut | None
    + create_order(payload: OrderCreate): OrderOut | None
    + process_payment(payload: PaymentOut): PaymentOut
  }
}

' =========================
' Application Services
' =========================

package "Application Services" {
  class CatalogService {
    + search(query: str): list[object]
  }

  class OrderService {
    + place_order(order: Order): Order
  }

  class PaymentService {
    + process_payment(payment: Payment): Payment
  }

  class ShipmentService {
    + ship(shipment: Shipment): Shipment
  }
}

' =========================
' Account / Customer
' =========================

package "Account / Customer" {
  class Account {
    - user_name: Username
    - password: Password
    - status: AccountStatus
    - name: Name
    - shipping_address: Address
    - email: Email
    - phone: Phone
    - credit_card: CreditCard | None
    - electronic_bank_transfer: ElectronicBankTransfer | None
    + get_shipping_address(): Address
  }

  class Customer {
    - shopping_cart: ShoppingCart
    - orders: list[Order]
    + get_shopping_cart(): ShoppingCart
    + place_order(): Order
    + add_product_review(product: Product): ProductReview
  }

  class Guest {
    + register_account(): Account
  }

  class Admin {
    - products: list[Product]
    - product_categories: list[ProductCategory]
    + block_user(account: Account): bool
    + add_product(product: Product): Product
    + add_new_product_category(category: ProductCategory): ProductCategory
    + modify_product_category(category: ProductCategory): ProductCategory
  }
}

' =========================
' Catalog / Product
' =========================

package "Catalog / Product" {
  class Catalog {
    - last_updated: CreationDate
    - product_names: ProductNameMap
    - product_categories: ProductCategoryMap
    - name: Name
    - products: list[Product]
    + search_products_by_name(name: ProductName): list[Product]
    + search_products_by_category(category: CategoryName): list[Product]
  }

  class ProductCategory {
    - category_id: CategoryId | None
    - name: CategoryName
    - description: CategoryDescription
    - slug: CategorySlug
  }

  class Product {
    - product_id: ProductId | None
    - name: ProductName
    - description: ProductDescription
    - price: Price
    - category: ProductCategory
    - slug: ProductSlug
    - variants: list[ProductVariant]
    - images: list[ProductImage]
    - metadata: dict[str, object]
    + get_available_count(): ProductCount
    + get_default_variant(): ProductVariant
    + find_variant(variant_id: ProductVariantId): ProductVariant | None
    + is_available(requested_quantity: int = 1): bool
  }

  class ProductVariant {
    - variant_id: ProductVariantId
    - name: ProductVariantName
    - sku: Sku
    - price: Price
    - inventory_count: ProductCount
    - currency_code: CurrencyCode
    - manages_inventory: bool
    - allows_backorder: bool
    + is_available(requested_quantity: int = 1): bool
  }

  class ProductImage {
    - image_id: ProductImageId
    - url: ProductImageUrl
    - rank: int
  }

  class ProductReview {
    - rating: Rating
    - review: ReviewContent
    - product: Product
    + get_rating(): Rating
  }
}

' =========================
' Cart / Order
' =========================

package "Cart / Order" {
  class ShoppingCart {
    - cart_id: CartId | None
    - region_id: RegionId | None
    - currency_code: CurrencyCode
    - email: CustomerEmail | None
    - locale: LocaleCode | None
    - items: list[CartItem]
    + total_quantity: int
    + subtotal: float
    + add_item(item: CartItem): bool
    + remove_item(item_id: CartItemId): bool
    + get_items(): list[CartItem]
  }

  class CartItem {
    - item_id: CartItemId | None
    - product: Product
    - product_variant: ProductVariant
    - quantity: Quantity
    - price: Price
    + subtotal: float
    + update_quantity(quantity: Quantity): bool
  }

  class Order {
    - order_id: OrderId | None
    - display_order_id: DisplayOrderId | None
    - order_number: OrderNumber
    - status: OrderStatus
    - refund_status: RefundStatus
    - order_date: OrderDate | None
    - items: list[OrderItem]
    - order_logs: list[OrderLog]
    - shipments: list[Shipment]
    - payment: Payment | None
    - email: CustomerEmail | None
    - region_id: RegionId | None
    - currency_code: CurrencyCode
    + subtotal: float
    + send_for_shipment(): bool
  }

  class OrderItem {
    - order_item_id: OrderItemId | None
    - product_id: ProductId
    - product_name: ProductName
    - product_variant_id: ProductVariantId
    - unit_price: Price
    - quantity: Quantity
    + subtotal: float
  }

  class OrderLog {
    - creation_date: CreationDate
    - status: OrderStatus
    - notifications: list[Notification]
  }
}

' =========================
' Payment
' =========================

package "Payment/" {
  class CreditCard {
    - name_on_card: Name
    - card_number: CardNumber
    - code: Code
    - billing_address: BillingAddress
  }

  class ElectronicBankTransfer {
    - bank_name: BankName
    - routing_number: RoutingNumber
    - account_number: AccountNumber
  }

  class PaymentMethod {
    - method_type: PaymentMethodType
    - credit_card: CreditCard | None
    - electronic_bank_transfer: ElectronicBankTransfer | None
  }

  class PaymentTransaction {
    - transaction_id: TransactionId | None
    - provider: PaymentProvider | None
    - status: PaymentStatus
    - created_on: CreationDate | None
  }

  class Payment {
    - payment_id: PaymentId | None
    - status: PaymentStatus
    - amount: Amount | None
    - currency: PaymentCurrencyCode | None
    - method: PaymentMethod | None
    - transaction: PaymentTransaction | None
    + process_payment(): PaymentStatus
  }
}

' =========================
' Shipment / Notification
' =========================

package "Shipment / Notification" {
  class Shipment {
    - shipment_date: ShipmentDate
    - estimated_arrival: EstimatedArrival
    - shipment_method: ShipmentMethod
    - shipment_logs: list[ShipmentLog]
    + add_shipment_log(): bool
  }

  class ShipmentLog {
    - status: ShipmentStatus
    - creation_date: CreationDate
    - notifications: list[Notification]
  }

  class Notification {
    - notification_id: NotificationId
    - channel: NotificationChannel
    - receiver: Contact
    - created_on: CreationDate
    - content: NotificationContent
    + send_notification(): bool
  }
}

' =========================
' Inheritance / Protocol
' =========================

Account <|-- Customer
Account <|-- Admin

Catalog ..|> Search

CategoryBase <|-- CategoryCreate
CategoryBase <|-- CategoryOut
ProductBase <|-- ProductCreate
ProductBase <|-- ProductOut

' =========================
' API Relationships
' =========================

FastAPIApp ..> HealthRouter
FastAPIApp ..> ProductRouter
FastAPIApp ..> RegionRouter
FastAPIApp ..> CartRouter
FastAPIApp ..> OrderRouter
FastAPIApp ..> PaymentRouter

ProductRouter ..> Store
CartRouter ..> Store
OrderRouter ..> Store
PaymentRouter ..> Store

Store *-- ProductOut : _products
Store *-- CartItemOut : _cart_items
Store *-- OrderOut : _orders
Store ..> ProductCreate
Store ..> CartItemCreate
Store ..> OrderCreate
Store ..> PaymentOut

ProductOut --> CategoryOut : category
CartItemOut --> ProductOut : product
ShoppingCartOut *-- CartItemOut : items
OrderCreate *-- CartItemCreate : items
OrderCreate o-- PaymentCreate : payment
OrderOut *-- CartItemOut : items
OrderOut o-- PaymentOut : payment
OrderOut *-- ShipmentOut : shipments

' =========================
' Service Relationships
' =========================

CatalogService ..> Catalog
OrderService ..> Order
PaymentService ..> Payment
ShipmentService ..> Shipment

' =========================
' Domain Relationships
' =========================

Guest ..> Account : register_account

Account o-- CreditCard : credit_card
Account o-- ElectronicBankTransfer : electronic_bank_transfer

Customer *-right- ShoppingCart
Customer o-- Order : orders
Customer --> ProductReview

Admin o-- Product : products
Admin o-- ProductCategory : product_categories

Catalog o-right- Product

Product -down-> ProductCategory : category
Product *-right- ProductVariant
Product *-down- ProductImage
ProductReview --> Product

ShoppingCart *-right- CartItem
CartItem --> Product
CartItem --> ProductVariant

Order *-right- OrderItem
Order *-- OrderLog
Order *-down- Shipment
Order o-left- Payment

Payment *-- PaymentMethod
Payment o-- PaymentTransaction
PaymentMethod o-- CreditCard
PaymentMethod o-- ElectronicBankTransfer
PaymentMethod --> PaymentMethodType

Shipment *-right- ShipmentLog
OrderLog o-- Notification : notifications
ShipmentLog o-- Notification : notifications
Notification --> NotificationChannel

' =========================
' Layout Helpers
' =========================

Account -[hidden]down- Customer
Catalog -[hidden]down- Product
ShoppingCart -[hidden]down- Order
Payment -[hidden]down- Shipment

@enduml
